# Enforce consistent line endings regardless of contributor OS.
# Prevents Windows clones from breaking shell scripts or JSON parsing.

*.sh    text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf

# Windows scripts must stay CRLF (and not show as phantom diffs in the dev container).
*.bat   text eol=crlf
*.cmd   text eol=crlf
